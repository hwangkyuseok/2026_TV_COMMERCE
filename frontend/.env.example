# ============================================================
# TV Commerce — 프론트엔드 환경변수 템플릿 (공유용)
# 이 파일을 복사하여 .env 로 저장 후 값을 채우세요.
#
#   cp frontend/.env.example frontend/.env
#
# .env 는 .gitignore 에 의해 Git에 올라가지 않습니다.
# 이 파일(.env.example)만 버전 관리 대상입니다.
# ============================================================

# ── API URL ───────────────────────────────────────────────────
# [핵심 주의] NEXT_PUBLIC_API_URL 은 "브라우저"가 실제로 요청을 보내는 주소입니다.
# Docker 내부 서비스명 'backend' 는 브라우저에서 해석되지 않습니다.
#
# [로컬 개발]
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# [Linux 서버 직접 접근]
#   NEXT_PUBLIC_API_URL=http://<SERVER_IP>:8000
#
# [Nginx 리버스 프록시 사용 시 (권장)]
#   NEXT_PUBLIC_API_URL=http://<SERVER_IP>/api
#
NEXT_PUBLIC_API_URL=http://localhost:8000
