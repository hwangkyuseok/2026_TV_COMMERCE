# ============================================================
# TV Commerce Platform — 환경변수 템플릿 (공유용)
# 이 파일을 복사하여 환경에 맞는 .env 로 저장 후 값을 채우세요.
#
#   로컬 개발:  cp .env.local .env
#   운영 배포:  cp .env.prod  .env
#
# .env, .env.local, .env.prod 는 .gitignore 에 의해 Git에 올라가지 않습니다.
# 이 파일(.env.example)만 버전 관리 대상입니다.
# ============================================================

# ── 포트 설정 ─────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── API URL ───────────────────────────────────────────────────
# [핵심 주의] NEXT_PUBLIC_API_URL 은 "브라우저"가 실제로 요청을 보내는 주소입니다.
# Docker 내부 서비스명 'backend' 는 브라우저에서 해석되지 않습니다.
#
# [로컬 개발]
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# [Linux 서버 직접 접근]
#   NEXT_PUBLIC_API_URL=http://<SERVER_IP>:8000
#
# [Nginx 리버스 프록시 사용 시 (권장)]
#   프론트·백엔드를 같은 도메인에서 서빙하면 CORS 불필요
#   NEXT_PUBLIC_API_URL=http://<SERVER_IP>/api
#
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS 허용 출처 ────────────────────────────────────────────
# 프로덕션에서는 * 대신 실제 프론트엔드 주소로 제한하세요.
# 여러 주소는 쉼표로 구분합니다.
#
# [개발 시]    CORS_ORIGINS=*
# [운영 시]    CORS_ORIGINS=http://<SERVER_IP>:3000
#
CORS_ORIGINS=*

# ── 크롤링 데이터 저장 경로 ────────────────────────────────────
# 이미지는 {HELLOVISION_DATA_DIR}/img/{rental,coupang,naver}/ 에 저장됩니다.
#
# [로컬 개발]
#   HELLOVISION_DATA_DIR=./HelloVision
#
# [Docker 운영] 컨테이너 내부 경로 (docker-compose.yml 볼륨 마운트로 호스트와 연결)
#   HELLOVISION_DATA_DIR=/app/HelloVision
#
HELLOVISION_DATA_DIR=./HelloVision

# ── PostgreSQL 데이터베이스 ────────────────────────────────────
# [방식 A] 단일 URL (DATABASE_URL 이 있으면 개별 항목보다 우선 적용됩니다)
#
# [로컬 개발 — 로컬 PostgreSQL 직접 실행 시]
#   DATABASE_URL=postgresql://tvuser:secret@localhost:5432/tvcommerce
#
# [Docker Compose 실행 시] — docker-compose.yml 이 자동 주입하므로 주석 유지 가능
#   DATABASE_URL=postgresql://tvuser:secret@db:5432/tvcommerce
#
DATABASE_URL=postgresql://tvuser:secret@localhost:5432/tvcommerce

# [방식 B] 항목별 개별 지정 (DATABASE_URL 이 없을 때만 사용됨)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tvcommerce
DB_USER=tvuser
DB_PASSWORD=secret
